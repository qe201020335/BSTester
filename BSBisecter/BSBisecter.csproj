<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net8.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
    </PropertyGroup>

    <ItemGroup>
      <ProjectReference Include="..\BSTester\BSTester.csproj" />
    </ItemGroup>

    <Target Name="Copy patches" AfterTargets="Build">
        <ItemGroup>
            <PatchFiles Include="$(ProjectDir)\..\patches\**\*.*" />
        </ItemGroup>
        <Copy SourceFiles="@(PatchFiles)" DestinationFolder="$(OutputPath)\patches\%(RecursiveDir)" SkipUnchangedFiles="false" />
    </Target>

</Project>
